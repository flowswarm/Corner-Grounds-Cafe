# Server Configuration
PORT=5000
NODE_ENV=development

# Database
# Using a localpostgres connection string as placeholder. 
# User needs to update this for their actual DB.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/corner_grounds_cafe

# Clover Configuration
# Placeholder keys. User MUST update these from their Clover App Dashboard.
CLOVER_CLIENT_ID=YOUR_CLOVER_APP_ID
CLOVER_CLIENT_SECRET=YOUR_CLOVER_APP_SECRET
CLOVER_REDIRECT_URI=http://localhost:3000/api/clover/oauth/callback
CLOVER_ENV=sandbox 
# Use 'https://sandbox.dev.clover.com' for sandbox or 'https://www.clover.com' for prod
CLOVER_BASE_URL=https://sandbox.dev.clover.com
