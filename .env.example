# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/corner_grounds_cafe

# Clover Configuration
CLOVER_CLIENT_ID=your_clover_client_id
CLOVER_CLIENT_SECRET=your_clover_client_secret
CLOVER_REDIRECT_URI=http://localhost:5000/api/clover/callback
CLOVER_ENV=sandbox

# Base URL for Redirects
BASE_URL=http://localhost:3000

# Email Configuration (SendGrid/SMTP)
EMAIL_SERVICE_API_KEY=your_email_api_key
NOTIFICATION_EMAIL=cafe@cornergrounds.com
