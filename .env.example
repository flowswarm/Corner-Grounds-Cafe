# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/corner_grounds_cafe

# Clover Configuration
CLOVER_CLIENT_ID=your_clover_client_id
CLOVER_CLIENT_SECRET=your_clover_client_secret
CLOVER_REDIRECT_URI=http://localhost:5000/api/clover/callback
CLOVER_ENV=sandbox

# Base URL for Redirects
BASE_URL=http://localhost:3000

# Email / SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Corner Grounds Cafe <noreply@cornergrounds.com>
